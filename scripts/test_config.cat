; Test config — ALL stats enabled, every flag exercised by test-commandline-args.sh

import "../config/distros.cat"

$layout           = "Inline"
$borderstyle      = "doubleline"
$stats_margin_top = 0
$location         = "San Francisco"

$stats = [
    {@username  icon='>'  name="user"      color=$red}
    {@hostname  icon='>'  name="hname"     color=$yellow}
    {@uptime    icon='>'  name="uptime"    color=$blue}
    {@distro    icon='>'  name="distro"    color=$green}
    {@kernel    icon='>'  name="kernel"    color=$magenta}
    {@desktop   icon='>'  name="desktop"   color=$cyan}
    {@terminal  icon='>'  name="term"      color=$red}
    {@shell     icon='>'  name="shell"     color=$magenta}
    {@separator color=$white}
    {@packages  icon='>'  name="packages"  color=$green}
    {@weather   icon='>'  name="weather"   color=$blue}
    {@gpu       icon='>'  name="gpu"       color=$magenta}
    {@cpu       icon='>'  name="cpu"       color=$red}
    {@battery   icon='>'  name="battery"   color=$green}
    {@memory    icon='>'  name="memory"    color=$yellow}
    {@disk_0    icon='>'  name="disk"      color=$green}
    {@colors    icon='>'  name="colors"    color=$reset  symbol='#'}
]
